<?xml version="1.0" encoding="utf-8" ?>
<configuration>
	<appSettings>
		<!-- Optional default environment when CAPHE_ENVIRONMENT is not set -->
		<add key="CaPheEnvironment" value="Development" />
		<!-- Optional hard-guard: true = child forms can only run inside MainForm -->
		<add key="EnforceEmbeddedChildForms" value="true" />
		<!-- Receipt printing identity -->
		<add key="Store.Name" value="CA PHE NAPOLE" />
		<add key="Store.Address" value="188 Le Loi, Quan 1, TP.HCM" />
		<add key="Store.Phone" value="0909 000 000" />
		<add key="Store.FooterLine1" value="Cam on quy khach va hen gap lai" />
		<add key="Store.FooterLine2" value="Hoa don da bao gom VAT (neu co)" />
		<add key="Store.FooterLine3" value="Lien he: 0909 000 000" />
	</appSettings>

	<connectionStrings>
		<!-- Local development fallback (non-secret) -->
		<add name="CaPheConnection.Development"
				 connectionString="Server=localhost\SQLEXPRESS;Database=QuanLyQuanCaPhe;Integrated Security=True;MultipleActiveResultSets=True;TrustServerCertificate=True"
				 providerName="System.Data.SqlClient" />

		<!-- Generic fallback when environment-specific keys are not provided -->
		<add name="CaPheConnection"
			 connectionString="Server=localhost\SQLEXPRESS;Database=QuanLyQuanCaPhe;Integrated Security=True;MultipleActiveResultSets=True;TrustServerCertificate=True"
			 providerName="System.Data.SqlClient" />
	</connectionStrings>
</configuration>